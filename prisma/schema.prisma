generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Per-user Saxo Bank credentials
// One row per Clerk user. Upserted on every successful OAuth connect.
model SaxoToken {
  id           String    @id @default(cuid())
  clerkUserId  String    @unique
  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  accountKey   String
  clientKey    String
  accountId    String
  environment  String    @default("sim") // "sim" | "live"
  expiresAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([clerkUserId])
}

// Optional: per-user Stripe subscription tracking
model Subscription {
  id            String    @id @default(cuid())
  clerkUserId   String    @unique
  stripeId      String?   @unique
  plan          String    @default("trial") // "trial" | "pro"
  status        String    @default("active") // "active" | "cancelled" | "past_due"
  currentPeriodEnd DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([clerkUserId])
}
