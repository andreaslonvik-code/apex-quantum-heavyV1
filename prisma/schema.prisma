generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Per-user Alpaca Trading credentials.
// One row per Clerk user. Inserted on /api/apex/alpaca/connect.
//
// API key + secret are encrypted at rest with AES-256-GCM (lib/crypto.ts).
// Stored format per encrypted column: "ivHex:tagHex:cipherHex".
// Decryption requires server-only ENCRYPTION_KEY env var.
model AlpacaAccount {
  id              String    @id @default(cuid())
  clerkUserId     String    @unique
  apiKeyEnc       String    @db.Text   // encrypted Alpaca API Key ID
  apiSecretEnc    String    @db.Text   // encrypted Alpaca API Secret
  environment     String    @default("paper") // "paper" | "live"
  accountId       String?   // Alpaca account number, populated on connect
  accountStatus   String?   // ACTIVE | ACCOUNT_UPDATED | etc.
  startBalance    Decimal   @default(0) @db.Decimal(18, 2)  // baseline equity at first connect
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([clerkUserId])
}

// Optional: per-user Stripe subscription tracking
model Subscription {
  id            String    @id @default(cuid())
  clerkUserId   String    @unique
  stripeId      String?   @unique
  plan          String    @default("trial") // "trial" | "pro"
  status        String    @default("active") // "active" | "cancelled" | "past_due"
  currentPeriodEnd DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([clerkUserId])
}
