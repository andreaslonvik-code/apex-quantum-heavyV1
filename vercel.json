{
  "crons": [
    {
      "path": "/api/cron/autonomous",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/learn",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/news-scan",
      "schedule": "* * * * *"
    }
  ],
  "functions": {
    "app/api/cron/autonomous/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/learn/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/news-scan/route.ts": {
      "maxDuration": 120
    },
    "app/api/apex/autonomous/route.ts": {
      "maxDuration": 60
    },
    "app/api/inngest/route.ts": {
      "maxDuration": 60
    }
  },
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
